#!/usr/bin/env bash
set -euo pipefail

INSTALL_DIR="$HOME/.local/share/autopilot"
HOST_NAME="com.profile_router.host"
EXTENSION_ID="eifgnohgbaefkgpgiipagieecnfjkome"
RAW_BASE="https://raw.githubusercontent.com/YOURUSER/autopilot/main"

echo "autopilot - installer"
echo "====================="
echo ""

# Check python3 is available
if ! command -v python3 &>/dev/null; then
  echo "Error: python3 is required but not found"
  exit 1
fi

# Detect browser and set paths
detect_browser() {
  if [ -d "$HOME/Library/Application Support/net.imput.helium" ]; then
    BROWSER_NAME="Helium"
    NATIVE_HOSTS_DIR="$HOME/Library/Application Support/net.imput.helium/NativeMessagingHosts"
  elif [ -d "$HOME/Library/Application Support/Google/Chrome" ]; then
    BROWSER_NAME="Chrome"
    NATIVE_HOSTS_DIR="$HOME/Library/Application Support/Google/Chrome/NativeMessagingHosts"
  elif [ -d "$HOME/Library/Application Support/BraveSoftware/Brave-Browser" ]; then
    BROWSER_NAME="Brave"
    NATIVE_HOSTS_DIR="$HOME/Library/Application Support/BraveSoftware/Brave-Browser/NativeMessagingHosts"
  elif [ -d "$HOME/Library/Application Support/Chromium" ]; then
    BROWSER_NAME="Chromium"
    NATIVE_HOSTS_DIR="$HOME/Library/Application Support/Chromium/NativeMessagingHosts"
  else
    echo "Error: No supported Chromium browser found."
    exit 1
  fi
}

detect_browser
echo "Detected browser: $BROWSER_NAME"
echo ""

# Create install directory
mkdir -p "$INSTALL_DIR"

# Download native host script
echo "Downloading native helper..."
curl -sL "$RAW_BASE/packages/native-host/host.py" -o "$INSTALL_DIR/host.py"
chmod +x "$INSTALL_DIR/host.py"

# Create default config if it doesn't exist
if [ ! -f "$INSTALL_DIR/config.json" ]; then
  echo '{"rules": []}' > "$INSTALL_DIR/config.json"
fi

# Create native messaging host manifest
mkdir -p "$NATIVE_HOSTS_DIR"
cat > "$NATIVE_HOSTS_DIR/$HOST_NAME.json" <<EOF
{
  "name": "$HOST_NAME",
  "description": "autopilot - opens URLs in the correct browser profile",
  "path": "$INSTALL_DIR/host.py",
  "type": "stdio",
  "allowed_origins": [
    "chrome-extension://$EXTENSION_ID/"
  ]
}
EOF

echo ""
echo "Installed:"
echo "  Helper:   $INSTALL_DIR/host.py"
echo "  Manifest: $NATIVE_HOSTS_DIR/$HOST_NAME.json"
echo ""
echo "Done! Open the autopilot extension in your browser to configure rules."

#!/usr/bin/env bash
set -euo pipefail

INSTALL_DIR="$HOME/.local/share/autopilot"
HOST_NAME="com.profile_router.host"
EXTENSION_ID="eifgnohgbaefkgpgiipagieecnfjkome"
RAW_BASE="https://raw.githubusercontent.com/dantemoon1/autopilot/main"

echo "autopilot - installer"
echo "====================="
echo ""

# Check python3 is available
if ! command -v python3 &>/dev/null; then
  echo "Error: python3 is required but not found."
  echo ""
  echo "Install it with:"
  echo "  xcode-select --install"
  exit 1
fi

# Helium only for now
NATIVE_HOSTS_DIR="$HOME/Library/Application Support/net.imput.helium/NativeMessagingHosts"

if [ ! -d "$HOME/Library/Application Support/net.imput.helium" ]; then
  echo "Error: Helium browser not found."
  echo "autopilot currently only supports Helium. More browsers coming soon."
  exit 1
fi

echo "Detected browser: Helium"
echo ""

# Create install directory
mkdir -p "$INSTALL_DIR"

# Download native host script
echo "Downloading native helper..."
if ! curl -sfL "$RAW_BASE/packages/native-host/host.py" -o "$INSTALL_DIR/host.py"; then
  echo "Error: Failed to download native helper."
  exit 1
fi
chmod +x "$INSTALL_DIR/host.py"

if ! curl -sfL "$RAW_BASE/uninstall.sh" -o "$INSTALL_DIR/uninstall.sh"; then
  echo "Error: Failed to download uninstaller."
  exit 1
fi
chmod +x "$INSTALL_DIR/uninstall.sh"

# Create default config if it doesn't exist
if [ ! -f "$INSTALL_DIR/config.json" ]; then
  echo '{"rules": []}' > "$INSTALL_DIR/config.json"
fi

# Create native messaging host manifest
mkdir -p "$NATIVE_HOSTS_DIR"
cat > "$NATIVE_HOSTS_DIR/$HOST_NAME.json" <<EOF
{
  "name": "$HOST_NAME",
  "description": "autopilot - opens URLs in the correct browser profile",
  "path": "$INSTALL_DIR/host.py",
  "type": "stdio",
  "allowed_origins": [
    "chrome-extension://$EXTENSION_ID/"
  ]
}
EOF

echo ""
echo "Installed:"
echo "  Helper:   $INSTALL_DIR/host.py"
echo "  Uninstall: $INSTALL_DIR/uninstall.sh"
echo "  Manifest: $NATIVE_HOSTS_DIR/$HOST_NAME.json"
echo ""
echo "Done! Open the autopilot extension in your browser to configure rules."
